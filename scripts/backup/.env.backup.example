# /root/VOD_Auctions/scripts/backup/.env.backup
# Copy this to .env.backup on VPS, fill in values, chmod 600.
# Sourced by _backup_common.sh.

# === Encryption ===
# 1Password: "VOD Backup GPG Passphrase" (Work)
GPG_PASSPHRASE=

# === Supabase Database URLs (for pg_dump) ===
# vod-auctions: falls leer, wird DATABASE_URL aus scripts/.env genutzt
SUPABASE_VOD_AUCTIONS_URL=
# blackfire: postgres://postgres:<password>@db.lglvuiuwbrhiqvxcriwa.supabase.co:5432/postgres
SUPABASE_BLACKFIRE_URL=

# === VPS-Local Databases (override defaults if needed) ===
# PG_LOCAL_DATABASES="stromportal"
# MYSQL_LOCAL_DATABASES="vodfest naegele_db"

# === Local Retention ===
LOCAL_RETENTION_DAYS=3
BACKUP_ROOT=/root/backups

# === Email Alerts (Resend) ===
# RESEND_API_KEY ist in backend/.env vorhanden, wird automatisch gesourced
BACKUP_ALERT_EMAIL=rseckler@gmail.com

# === Brevo ===
# BREVO_API_KEY ist in backend/.env vorhanden, wird automatisch gesourced

# === Uptime-Kuma Push-Heartbeat URLs ===
# 1Password: "VOD Uptime-Kuma Heartbeats" (Work) — alle 6 URLs
KUMA_BACKUP_VOD_AUCTIONS=
KUMA_BACKUP_BLACKFIRE=
KUMA_BACKUP_VPS=
KUMA_BACKUP_R2_IMAGES=
KUMA_BACKUP_BREVO=
KUMA_REPLICATION_LAG=
