# VOD Auctions — Storefront Staging Environment Variables (TEMPLATE)
#
# Used only when the staging HTTP layer is built (currently: DB-only, no
# staging storefront running). NEVER commit actual secrets. Fetch live
# values from 1Password at runtime.
#
# Staging Supabase project: vod-auctions-staging (ref: aebcwjjcextzvflrjgei)
# Region: eu-west-1 (Ireland)
# Account: "Supabase 2. Account" in 1Password
#
# General rule: every value here MUST point to a staging/sandbox/test
# equivalent of the production service. Never share secrets with production.

# ── Stripe (Test Mode) ────────────────────────────────────────────────────────
# Same test keys as local dev are fine — Stripe test mode is account-wide.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── PayPal (Sandbox) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=           # Sandbox client ID

# ── Supabase (Staging Project) ───────────────────────────────────────────────
# URL and anon key from the STAGING project, NOT production.
# Fetch: op item get "Supabase 2. Account" --fields URL,"Public Key" --reveal
NEXT_PUBLIC_SUPABASE_URL=https://aebcwjjcextzvflrjgei.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # From Supabase 2. Account → staging project → API

# ── Brevo ─────────────────────────────────────────────────────────────────────
# Use a separate Brevo client key for staging, or leave empty.
NEXT_PUBLIC_BREVO_CLIENT_KEY=

# ── Analytics (OFF for staging) ───────────────────────────────────────────────
# Staging should NEVER report analytics to production GA4 or Hotjar.
# Leave empty to disable, or use a dedicated staging GA4 property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_HOTJAR_ID=

# ── Sentry (Separate project or disabled) ─────────────────────────────────────
# Either a dedicated staging Sentry project or empty to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Upstash Redis (Separate DB) ──────────────────────────────────────────────
# Use a dedicated Upstash staging DB, or leave empty for in-memory fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App Config ────────────────────────────────────────────────────────────────
# Staging-specific: different gate password, different backend URL.
GATE_PASSWORD=vodstaging2026            # NOT the production gate password
REVALIDATE_SECRET=                      # Fresh random, matches backend/.env.staging
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api-staging.vod-auctions.com    # When HTTP layer is built
NEXT_PUBLIC_PUBLISHABLE_KEY=            # Medusa publishable key from the staging backend
