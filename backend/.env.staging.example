# VOD Auctions — Backend Staging Environment Variables (TEMPLATE)
#
# This template documents which variables differ from production for the
# staging environment. NEVER commit actual secrets. Fetch live values from
# 1Password at runtime.
#
# Staging Supabase project: vod-auctions-staging (ref: aebcwjjcextzvflrjgei)
# Region: eu-west-1 (Ireland)
# Account: separate Supabase account — 1Password entry "Supabase 2. Account"
#
# Connection pattern for admin ops (pg_dump, psql, migrations):
#   psql "postgresql://postgres.aebcwjjcextzvflrjgei:$PW@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
#
# Or use env-var form to avoid URL-escaping headaches with special characters:
#   PGHOST=aws-0-eu-west-1.pooler.supabase.com
#   PGPORT=5432
#   PGUSER=postgres.aebcwjjcextzvflrjgei
#   PGPASSWORD=$(op item get "Supabase 2. Account" --fields "Database password" --reveal)
#   PGDATABASE=postgres

# ── Database ──────────────────────────────────────────────────────────────────
# Session pooler (Port 5432) — required on Free plan; direct port 5432 is unreliable.
# Fetch password: op item get "Supabase 2. Account" --fields "Database password" --reveal
DATABASE_URL=postgresql://postgres.aebcwjjcextzvflrjgei:STAGING_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# ── Supabase ──────────────────────────────────────────────────────────────────
# Anon/publishable key and service role key from the STAGING project, NOT production.
# Get from: Supabase Dashboard → Project aebcwjjcextzvflrjgei → Settings → API
SUPABASE_SERVICE_ROLE_KEY=       # Staging service role (from Supabase 2. Account dashboard)

# ── Stripe ────────────────────────────────────────────────────────────────────
# Staging MUST use Stripe Test Mode — never the live keys. Use the same test keys
# as local dev; Stripe test mode is account-wide, not project-wide.
STRIPE_SECRET_KEY=sk_test_...    # Stripe TEST mode secret
STRIPE_WEBHOOK_SECRET=whsec_...  # Create separate webhook endpoint for staging domain

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=                # PayPal Sandbox account (not live)
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox              # MUST be sandbox for staging
PAYPAL_WEBHOOK_ID=               # Create separate sandbox webhook for staging

# ── Resend — Transactional Email ──────────────────────────────────────────────
# Use a separate Resend test/dev API key so staging emails don't land in production inboxes.
# Or: set RESEND_API_KEY to an invalid value to disable email entirely in staging.
RESEND_API_KEY=                  # Test key OR empty (emails silently skipped)

# ── Brevo — Email Marketing & CRM ────────────────────────────────────────────
# Do NOT point staging at production Brevo lists. Either disable or use test lists.
BREVO_API_KEY=                   # Empty or test key
BREVO_LIST_VOD_AUCTIONS=         # Empty or dedicated test list
BREVO_LIST_TAPE_MAG=             # Empty or dedicated test list
BREVO_SENDER_EMAIL=newsletter@vod-auctions.com
BREVO_SENDER_NAME=VOD Auctions [STAGING]

# ── App URLs ──────────────────────────────────────────────────────────────────
# When the HTTP layer is built, these will point to the staging subdomains.
# Until then, staging runs DB-only and these values are unused.
STOREFRONT_URL=https://staging.vod-auctions.com
REVALIDATE_SECRET=               # Different from production — random ≥ 32 chars

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be different from production. Generate fresh random values for staging:
#   COOKIE_SECRET=$(openssl rand -hex 32)
#   JWT_SECRET=$(openssl rand -hex 32)
COOKIE_SECRET=                   # Fresh random ≥ 32 chars, NOT production value
JWT_SECRET=                      # Fresh random ≥ 32 chars, NOT production value

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Use a separate Upstash database for staging to avoid cache collisions.
# Or: leave empty to fall back to in-memory (fine for low-traffic staging).
REDIS_URL=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Use a separate API key with low spending limit for staging, or share dev key.
ANTHROPIC_API_KEY=               # Dev/test key, not production

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Staging is the safe place to flip experimental flags before production.
# Flag state is stored in site_config.features (JSONB) per-database, so staging
# flag state is completely independent from production.
