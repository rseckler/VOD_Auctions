# VOD Auctions — Backend Environment Variables
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=                    # PostgreSQL connection string (Supabase: Settings > Database > Connection string)
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=       # From Supabase > Project Settings > API > service_role key
                                 # Required for Anti-Sniping Realtime Broadcast (lot_extended event)

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=               # From Stripe Dashboard > Developers > API Keys > Secret key
STRIPE_WEBHOOK_SECRET=           # From Stripe Dashboard > Developers > Webhooks > Signing secret
                                 # Endpoint: https://api.vod-auctions.com/webhooks/stripe
                                 # Events: checkout.session.completed/expired, payment_intent.succeeded/payment_failed

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=                # From PayPal Developer > Apps & Credentials > Client ID
PAYPAL_CLIENT_SECRET=            # From PayPal Developer > Apps & Credentials > Client Secret
PAYPAL_MODE=live                 # live or sandbox
PAYPAL_WEBHOOK_ID=               # From PayPal Developer > Webhooks > Webhook ID (e.g. 95847304EJ582074L)

# ── Resend — Transactional Email ──────────────────────────────────────────────
RESEND_API_KEY=                  # From Resend Dashboard > API Keys
                                 # Sender: noreply@vod-auctions.com (interim; target: notifications@)
EMAIL_FROM="VOD Auctions <noreply@vod-auctions.com>"

# ── Public contact addresses (mailboxes + aliases at all-inkl) ────────────────
# support@ and privacy@ are real mailboxes. info@, billing@, orders@, abuse@,
# postmaster@ forward to support@. frank@, press@ forward to Frank.
SUPPORT_EMAIL=support@vod-auctions.com
PRIVACY_EMAIL=privacy@vod-auctions.com

# ── Brevo — Email Marketing & CRM ────────────────────────────────────────────
BREVO_API_KEY=                   # From Brevo Dashboard > Account > SMTP & API > API Keys
BREVO_LIST_VOD_AUCTIONS=4        # List ID for VOD Auctions subscribers (check Brevo > Contacts > Lists)
BREVO_LIST_TAPE_MAG=5            # List ID for tape-mag contacts (imported 3.580 contacts)
BREVO_SENDER_EMAIL=newsletter@vod-auctions.com
BREVO_SENDER_NAME=VOD Auctions

# ── App URLs ──────────────────────────────────────────────────────────────────
STOREFRONT_URL=https://vod-auctions.com
REVALIDATE_SECRET=               # Random secret shared with storefront for ISR revalidation

# ── Security ──────────────────────────────────────────────────────────────────
COOKIE_SECRET=                   # Random string ≥ 32 chars for session cookies
JWT_SECRET=                      # Random string ≥ 32 chars for JWT tokens

# ── ERP — Sendcloud / DHL (activate when ERP_SENDCLOUD flag goes live) ─────────
DHL_ACCOUNT_NUMBER=              # DHL Geschäftskundennummer (5115313430)
SENDCLOUD_PUBLIC_KEY=            # From Sendcloud Dashboard > Settings > API
SENDCLOUD_SECRET_KEY=            # From Sendcloud Dashboard > Settings > API

# ── ERP — easybill (activate when ERP_INVOICING flag goes live) ────────────────
EASYBILL_API_KEY=                # From easybill Dashboard > Einstellungen > API

# ── AI — Anthropic Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=               # From console.anthropic.com > API Keys
                                 # Used for: AI Chat (Haiku 4.5) + AI Create Auction (Sonnet 4.6)

# ── AI — MiniMax (LLM, Token Plan Subscription) ───────────────────────────────
MINIMAX_API_KEY=                 # 1Password Work > "MINIMAX API Token Plan" > Token Plan Key
                                 # Model: MiniMax-M2 (reasoning, 1M context, OpenAI-compatible)
                                 # Use cases: Stammdaten-Bulk-Backfill, Briefings, Summaries (no customer PII)
MINIMAX_API_HOST=https://api.minimax.io

# ── AI — MiniMax Multimodal (OpenClaw, pay-as-you-go, funded separately) ──────
# MINIMAX_API_KEY_MULTIMODAL=    # 1Password Work > "MINIMAX API Key OpenClaw" > API Key
                                 # Used for: TTS, Image-Gen, Video-Gen (Hailuo) — needs balance top-up first

# ── Search — Meilisearch ──────────────────────────────────────────────────────
MEILI_URL=http://127.0.0.1:7700  # Self-hosted on VPS (Docker)
MEILI_ADMIN_API_KEY=             # 1Password Work > "VOD Meilisearch Master Key"

# ── Cloudflare R2 — Image Storage ────────────────────────────────────────────
R2_ACCESS_KEY_ID=                # From Cloudflare R2 > API Tokens
R2_SECRET_ACCESS_KEY=            # From Cloudflare R2 > API Tokens
